{
  "name": "blueprint",
  "version": "1.0.0",
  "description": "",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5173 && tsc -p tsconfig.main.json && cross-env NODE_ENV=development electron .",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:renderer && npm run build:main",
    "start": "electron ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Misasag/Blueprint.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Misasag/Blueprint/issues"
  },
  "homepage": "https://github.com/Misasag/Blueprint#readme",
  "build": {
    "appId": "com.blueprint.ui-editor",
    "productName": "Blueprint",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      { "from": "assets", "to": "assets" }
    ],
    "win": { "icon": "assets/icon.png" },
    "mac": { "icon": "assets/icon.png" },
    "linux": { "icon": "assets/icon.png" }
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "wait-on": "^9.0.4"
  }
}
